# =============================================================================
# AICodeGenCrew - .gitignore
# Stack: Python 3.12 | Angular 19 | Node | Docker | CrewAI | ChromaDB
# =============================================================================

# =============================================================================
# SECRETS & ENVIRONMENT
# =============================================================================
.env
.env.*
CLAUDE.md
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/*
!dist/release-template/
!dist/release-template/**
eggs/
.eggs/
*.egg-info/
*.egg
.installed.cfg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
sdist/
wheels/
share/python-wheels/

# Virtual Environments
.venv/
venv/
env/
ENV/
.conda/

# Packaging
*.manifest
*.spec
.pybuilder/

# =============================================================================
# NODE / ANGULAR
# =============================================================================
node_modules/
.angular/
.sass-cache/
ui/frontend/dist/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# TESTING & COVERAGE
# =============================================================================
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
.nox/
coverage.xml
test-results/
coverage/
playwright-report/
*.cover
*.py,cover
.hypothesis/

# =============================================================================
# IDE & EDITORS
# =============================================================================
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# =============================================================================
# CLAUDE CODE
# =============================================================================
.claude/

# =============================================================================
# DOCKER
# =============================================================================
docker-compose.override.yml

# =============================================================================
# LOGS (root-level only, not ui/frontend/src/app/pages/logs/)
# =============================================================================
/logs/
ui/backend/logs/
ui/logs/
*.log

# =============================================================================
# CACHE & DATABASES
# =============================================================================
.cache/
*.db
*.sqlite3

# =============================================================================
# TEMPORARY & BACKUP
# =============================================================================
*.tmp
*.temp
*.bak
*.backup
*.orig
*~

# =============================================================================
# PROJECT-SPECIFIC: Runtime & Generated Files
# =============================================================================

# Runtime generated files
nul
discovered_files.txt
indexing_output.log
indexed_files.txt
SESSION_STATE.md

# Input files (user-provided JIRA/DOCX/Excel — external to repo)
inputs/

# Phase 3 architecture docs export (DOCS_OUTPUT_DIR)
architecture-docs/

# Knowledge backup folders (timestamped runs)
knowledge-*/

# Knowledge runtime outputs (per-phase isolation)
knowledge/discover/
knowledge/extract/
knowledge/analyze/
knowledge/document/
knowledge/plan/
knowledge/implement/
knowledge/verify/
knowledge/deliver/
knowledge/run_report.json

# Checkpoint files (Phase 3 resume state)
.checkpoint_*.json

# Legacy paths (should not be created)
knowledge/architecture/
knowledge/archive/

# Reports (regenerated)
reports/*.md

# =============================================================================
# KEEP EMPTY DIRECTORIES
# =============================================================================
!knowledge/.gitkeep
!reports/.gitkeep
!logs/.gitkeep

# =============================================================================
# PRESENTATIONS & MARKETING ASSETS (not source code)
# =============================================================================
*.pptx
*.ppt
fill_pptx.py
sdlc_overview.png

# Backend build artifacts
ui/backend/src_bundle/
ui/backend/certs/
certs/
