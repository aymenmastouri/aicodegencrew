# =============================================================================
# AICodeGenCrew - .gitignore
# Stack: Python 3.12 | Angular 19 | Node | Docker | CrewAI | ChromaDB
# =============================================================================

# =============================================================================
# SECRETS & ENVIRONMENT
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
eggs/
.eggs/
*.egg-info/
*.egg
.installed.cfg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
sdist/
wheels/
share/python-wheels/

# Virtual Environments
.venv/
venv/
env/
ENV/
.conda/

# Packaging
*.manifest
*.spec
.pybuilder/

# =============================================================================
# NODE / ANGULAR
# =============================================================================
node_modules/
.angular/
.sass-cache/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# TESTING & COVERAGE
# =============================================================================
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
.nox/
coverage.xml
test-results/
coverage/
playwright-report/
*.cover
*.py,cover
.hypothesis/

# =============================================================================
# IDE & EDITORS
# =============================================================================
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# =============================================================================
# CLAUDE CODE
# =============================================================================
.claude/

# =============================================================================
# DOCKER
# =============================================================================
docker-compose.override.yml

# =============================================================================
# LOGS (root-level only, not ui/frontend/src/app/pages/logs/)
# =============================================================================
/logs/
*.log

# =============================================================================
# CACHE & DATABASES
# =============================================================================
.cache/
*.db
*.sqlite3

# =============================================================================
# TEMPORARY & BACKUP
# =============================================================================
*.tmp
*.temp
*.bak
*.backup
*.orig
*~

# =============================================================================
# PROJECT-SPECIFIC: Runtime & Generated Files
# =============================================================================

# Runtime generated files
nul
discovered_files.txt
indexing_output.log
indexed_files.txt
SESSION_STATE.md

# Input files (user-provided JIRA/DOCX/Excel — external to repo)
inputs/

# Phase 3 architecture docs export (DOCS_OUTPUT_DIR)
architecture-docs/

# Knowledge backup folders (timestamped runs)
knowledge-*/

# Knowledge runtime outputs
knowledge/architecture/evidence/
knowledge/architecture/archive/
knowledge/architecture/.checkpoint_*.json
knowledge/development/*.json
knowledge/codegen/*.json
knowledge/run_report.json

# Reports (regenerated)
reports/*.md

# =============================================================================
# KEEP EMPTY DIRECTORIES
# =============================================================================
!knowledge/.gitkeep
!knowledge/architecture/.gitkeep
!reports/.gitkeep
!logs/.gitkeep
