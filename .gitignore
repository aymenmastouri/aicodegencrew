# -----------------------------------------------------------------------------
# Generated Knowledge (Runtime Output)
# -----------------------------------------------------------------------------
# Phase 1 outputs (regenerated each run)
knowledge/architecture/architecture_facts.json
knowledge/architecture/evidence_map.json
knowledge/architecture/evidence/

# Phase 2 outputs (regenerated each run)
knowledge/architecture/arc42/*.md
knowledge/architecture/c4/*.md
knowledge/architecture/c4/diagrams/*.drawio
knowledge/architecture/quality/

# Reports (regenerated)
reports/*.md
!reports/.gitkeep

# -----------------------------------------------------------------------------
# Keep Empty Directories
# -----------------------------------------------------------------------------
!knowledge/.gitkeep
!knowledge/architecture/.gitkeep
!reports/.gitkeep
!logs/.gitkeep
