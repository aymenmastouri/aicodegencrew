## Level 2: Container Diagram

The Container diagram shows the high-level technology choices.

```mermaid
C4Container
    title Container Diagram - {{ project_name | default("System") }}
    
    {% for actor in actors | default([]) %}
    Person({{ actor.id }}, "{{ actor.name }}", "{{ actor.description }}")
    {% endfor %}
    
    System_Boundary(systemBoundary, "{{ project_name | default('System') }}") {
        {% for container in containers | default([]) %}
        Container({{ container.id }}, "{{ container.name }}", "{{ container.technology }}", "{{ container.description }}")
        {% endfor %}
        
        {% for db in databases | default([]) %}
        ContainerDb({{ db.id }}, "{{ db.name }}", "{{ db.technology }}", "{{ db.description }}")
        {% endfor %}
    }
    
    {% for external in external_systems | default([]) %}
    System_Ext({{ external.id }}, "{{ external.name }}", "{{ external.description }}")
    {% endfor %}
    
    {% for rel in container_relationships | default([]) %}
    Rel({{ rel.from }}, {{ rel.to }}, "{{ rel.description }}"{{ ', "' + rel.technology + '"' if rel.technology else '' }})
    {% endfor %}
```

