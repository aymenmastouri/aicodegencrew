# AI Code Generation Crew - Configuration

# Repository
PROJECT_PATH=C:\path\to\your\repo
INCLUDE_SUBMODULES=true

# Phase 4: Task Understanding - Input Folders
TASK_INPUT_DIR=./inputs/tasks              # Task descriptions (JIRA XML, DOCX, PDF, etc.)
REQUIREMENTS_DIR=./inputs/requirements     # Requirements docs (Excel, DOCX, PDF)
LOGS_DIR=./inputs/logs                     # Log files (.log, .txt, .xlsx)
REFERENCE_DIR=./inputs/reference           # Reference docs (mockups, diagrams, etc.)

# LLM Provider (onprem Capgemini)
LLM_PROVIDER=onprem
MODEL=gpt-oss-120b
API_BASE=http://sov-ai-platform.nue.local.vm:4000/v1
OPENAI_API_KEY=your-api-key-here

# Token limits (optimized for gpt-oss-120b: 120K context window)
MAX_LLM_INPUT_TOKENS=100000
MAX_LLM_OUTPUT_TOKENS=16000
LLM_CONTEXT_WINDOW=120000

# LLM Retry Settings
LLM_NUM_RETRIES=10
LLM_RETRY_DELAY=5

# Embeddings (local Ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_S=300
OLLAMA_MAX_RETRIES=3
EMBED_MODEL=all-minilm:latest
NO_PROXY=localhost,127.0.0.1

# Embedding batching
EMBED_USE_BATCHING=true
EMBED_BATCH_SIZE=50
EMBED_PAUSE_EVERY=200
EMBED_PAUSE_S=1.0
EMBED_MAX_TEXT_LENGTH=1200

# Indexing
INDEX_MODE=auto
INDEX_EXTRA_SKIP_DIRS=dist,out,coverage,_generated,html,build,target,.gradle,.idea,.vscode,.m2,test-results,documents-unused,.continue,e2e-xnp
INDEX_EXTENSIONS=.java,.kt,.kts,.groovy,.gradle,.xml,.properties,.yml,.yaml,.json,.md,.ts,.tsx,.js,.jsx,.sh

# ChromaDB
CHROMA_DIR=.cache\.chroma
INDEX_MAX_FILES_BACKEND=8000
INDEX_MAX_FILES_FRONTEND=8000
INDEX_LOCK_TIMEOUT_S=600

# Chunking
CHUNK_CHARS=1200
CHUNK_OVERLAP=150
MAX_FILE_BYTES=1000000
INDEX_MAX_TOTAL_FILES=10000
INDEX_MAX_TOTAL_CHUNKS=100000
INDEX_BATCH_SIZE=50

# RAG limits
MAX_RAG_RESULTS=15
MAX_EVIDENCE_PER_ITEM=5

# Token budget is calculated from MAX_LLM_INPUT_TOKENS (see token_budget.py)
# Tool responses use 25% of input budget = 8000 tokens = ~32000 chars

# Output
OUTPUT_DIR=./knowledge/architecture

# Logging
LOG_LEVEL=INFO
CREWAI_TRACING_ENABLED=false
