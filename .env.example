# Path to the repository to analyze
PROJECT_PATH=C:\path\to\your\repo

# Task and reference input directories
TASK_INPUT_DIR=C:\work\my-project\tasks
REQUIREMENTS_DIR=C:\work\my-project\requirements
LOGS_DIR=C:\work\my-project\logs
REFERENCE_DIR=C:\work\my-project\reference

# ── Capgemini Sovereign AI Platform ─────────────────────────────────────────
# External:  https://litellm.bnotk.sovai-de.apps.ce.capgemini.com/v1
# Internal:  http://bnotk_litellm:4000/v1
LLM_PROVIDER=onprem
API_BASE=https://litellm.bnotk.sovai-de.apps.ce.capgemini.com/v1
OPENAI_API_KEY=sk-gX7FLpLxfFUyORK8rv1Rog

# Kimi-K2.5 (1T MoE, 32B active, 384 experts, 196K ctx) — architecture, planning, reviews
MODEL=openai/complex_tasks

# GPT-OSS-120B (MoE, 5.1B active, 131K ctx) — fast tasks (triage, classification)
FAST_MODEL=openai/chat

# Qwen3-Coder-Next (80B MoE, 3B active, 256K ctx) — code generation, tool use, agentic coding
CODEGEN_MODEL=openai/code

# Mistral-Small-3.1-24B-Instruct (24B, 131K ctx, EU) — OCR, documents, multilingual
VISION_MODEL=openai/vision

# ── Token limits ─────────────────────────────────────────────────────────────
MAX_LLM_OUTPUT_TOKENS=8000
LLM_CONTEXT_WINDOW=196608

# ── Embeddings (via platform) ────────────────────────────────────────────────
EMBED_MODEL=embed

# ── Output & indexing ────────────────────────────────────────────────────────
INDEX_MODE=auto
OUTPUT_DIR=./knowledge/architecture
DOCS_OUTPUT_DIR=./architecture-docs

# ── Logging & tracing ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
CREWAI_TRACING_ENABLED=false

# ── ChromaDB (optional: client-server mode) ──────────────────────────────────
# If CHROMA_SERVER_HOST is set, semantic search uses HTTP instead of local SQLite.
# Start: chroma run --path knowledge/discover --host 127.0.0.1 --port 8005
# CHROMA_SERVER_HOST=127.0.0.1
# CHROMA_SERVER_PORT=8005
# CHROMA_SERVER_SSL=false

# ── Code generation ──────────────────────────────────────────────────────────
# Skip build verification when VPN is active (VPN breaks Gradle builds)
# CODEGEN_BUILD_VERIFY=false
