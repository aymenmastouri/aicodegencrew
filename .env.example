# Path to the repository to analyze
PROJECT_PATH=C:\path\to\your\repo

# Task and reference input directories
TASK_INPUT_DIR=C:\work\my-project\tasks
REQUIREMENTS_DIR=C:\work\my-project\requirements
LOGS_DIR=C:\work\my-project\logs
REFERENCE_DIR=C:\work\my-project\reference

# LLM provider
LLM_PROVIDER=onprem
MODEL=gpt-oss-120b
API_BASE=http://sov-ai-platform.nue.local.vm:4000/v1
OPENAI_API_KEY=your-api-key-here
INDEX_MODE=auto
LOG_LEVEL=INFO
MAX_LLM_INPUT_TOKENS=120000
MAX_LLM_OUTPUT_TOKENS=8000
LLM_CONTEXT_WINDOW=130000

# Embeddings
OLLAMA_BASE_URL=http://127.0.0.1:11434
EMBED_MODEL=nomic-embed-text:latest

# ChromaDB (optional: client-server mode)
# If CHROMA_SERVER_HOST is set, semantic search uses HTTP (no local SQLite/PersistentClient in the pipeline process).
# Start the service separately, e.g.:
#   chroma run --path knowledge/discover --host 127.0.0.1 --port 8005
# Then set:
# CHROMA_SERVER_HOST=127.0.0.1
# CHROMA_SERVER_PORT=8005
# CHROMA_SERVER_SSL=false

# Architecture docs export directory
DOCS_OUTPUT_DIR=./architecture-docs

# Code generation: skip build verification (useful when VPN breaks builds)
# CODEGEN_BUILD_VERIFY=false
