# Path to the repository to analyze
PROJECT_PATH=/path/to/your/repo

# Task and reference input directories (upload via Dashboard or place files here)
TASK_INPUT_DIR=./inputs/tasks
REQUIREMENTS_DIR=./inputs/requirements
LOGS_DIR=./inputs/logs
REFERENCE_DIR=./inputs/reference

# ── LLM Configuration ──────────────────────────────────────────────────────
# Provider: "onprem" (LiteLLM/vLLM), "openai" (OpenAI API), "ollama" (local)
#
# Example: Capgemini Sovereign AI Platform
#   LLM_PROVIDER=onprem
#   API_BASE=https://your-litellm-proxy.example.com/v1
#
# Example: OpenAI
#   LLM_PROVIDER=openai
#   API_BASE=https://api.openai.com/v1
#
# Example: Ollama (local)
#   LLM_PROVIDER=ollama
#   API_BASE=http://localhost:11434/v1
#
LLM_PROVIDER=onprem
API_BASE=https://your-llm-endpoint.example.com/v1
OPENAI_API_KEY=sk-your-api-key-here

# Qwen3-Coder-Next (80B MoE, 3B active, 256K ctx) — architecture, documentation, planning
MODEL=openai/code

# Same model for all tasks (simplifies configuration)
FAST_MODEL=openai/code

# Qwen3-Coder-Next (80B MoE, 3B active, 256K ctx) — code generation, tool use, agentic coding
CODEGEN_MODEL=openai/code

# Mistral-Small-3.1-24B-Instruct (24B, 131K ctx, EU) — OCR, documents, multilingual
VISION_MODEL=openai/vision

# ── Token limits ─────────────────────────────────────────────────────────────
MAX_LLM_OUTPUT_TOKENS=65536
LLM_CONTEXT_WINDOW=262144

# ── Embeddings (via platform) ────────────────────────────────────────────────
EMBED_MODEL=embed

# ── Output & indexing ────────────────────────────────────────────────────────
INDEX_MODE=auto
OUTPUT_DIR=./knowledge/architecture
DOCS_OUTPUT_DIR=./architecture-docs

# ── Logging & tracing ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
CREWAI_TRACING_ENABLED=false

# ── Timezone (used in Docker containers) ─────────────────────────────────────
# TZ=Europe/Berlin

# ── ChromaDB (optional: client-server mode) ──────────────────────────────────
# If CHROMA_SERVER_HOST is set, semantic search uses HTTP instead of local SQLite.
# Start: chroma run --path knowledge/discover --host 127.0.0.1 --port 8005
# CHROMA_SERVER_HOST=127.0.0.1
# CHROMA_SERVER_PORT=8005
# CHROMA_SERVER_SSL=false

# ── Code generation ──────────────────────────────────────────────────────────
# Skip build verification (useful when build tools are unavailable)
# CODEGEN_BUILD_VERIFY=false

# ══════════════════════════════════════════════════════════════════════════════
# On-Prem Platform Services (all optional, all remote — nothing runs locally)
# ══════════════════════════════════════════════════════════════════════════════

# ── Langfuse LLM Observability ───────────────────────────────────────────────
# Traces every LLM call via LiteLLM's native Langfuse integration.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://langfuse.bnotk.sovai-de.apps.ce.capgemini.com

# ── Prometheus / Grafana Metrics ─────────────────────────────────────────────
# Expose /metrics endpoint in Prometheus text format for Grafana dashboards.
# PROMETHEUS_ENABLED=false

# ── MLflow Experiment Tracking ───────────────────────────────────────────────
# Track pipeline runs, phase metrics, and artifacts in MLflow.
# MLFLOW_TRACKING_URI=https://mlflow.bnotk.sovai-de.apps.ce.capgemini.com
# MLFLOW_EXPERIMENT_NAME=aicodegencrew
# MLFLOW_S3_ENDPOINT_URL=https://minio.bnotk.sovai-de.apps.ce.capgemini.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Qdrant Vector Store (alternative to ChromaDB) ───────────────────────────
# Switch between ChromaDB (default) and Qdrant for vector search.
# VECTOR_DB=chroma
# QDRANT_URL=https://qdrant.bnotk.sovai-de.apps.ce.capgemini.com
# QDRANT_API_KEY=
# QDRANT_COLLECTION=repo_docs

# ── Neo4J Knowledge Graph ───────────────────────────────────────────────────
# Export architecture facts as a graph database for dependency analysis.
# NEO4J_URI=bolt://neo4j.bnotk.sovai-de.apps.ce.capgemini.com:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# ── Docling Document Conversion ─────────────────────────────────────────────
# PDF/DOCX/PPTX → Markdown via Docling REST API (platform service).
# DOCLING_URL=https://docling.bnotk.sovai-de.apps.ce.capgemini.com

# ── SovAI MCP Server ────────────────────────────────────────────────────────
# Sovereign AI platform MCP tools for architecture analysis and planning.
# SOVAI_MCP_URL=https://sovai-mcp.bnotk.sovai-de.apps.ce.capgemini.com

# ── MCPO HTTP Transport ─────────────────────────────────────────────────────
# Route MCP tool calls through MCPO HTTP proxy instead of stdio.
# MCP_TRANSPORT=stdio
# MCPO_URL=https://mcpo.bnotk.sovai-de.apps.ce.capgemini.com

# ── Authentik OIDC Authentication ────────────────────────────────────────────
# Protect the dashboard with OpenID Connect via Authentik (platform service).
# OIDC_ENABLED=false
# OIDC_AUTHORITY=https://authentik.bnotk.sovai-de.apps.ce.capgemini.com/application/o/aicodegencrew
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_SCOPES=openid profile email
