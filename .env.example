# =============================================================================
# SDLC Pilot — Configuration
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Quick start with Ollama (local, free):
#   1. Install Ollama: https://ollama.com
#   2. ollama pull qwen3.5
#   3. ollama pull nomic-embed-text
#   4. cp .env.example .env
#   5. Edit PROJECT_PATH below
#   6. Start platform: docker-compose -f docker-compose.local.yml up -d
#   7. npm run dev
#
# =============================================================================

# Path to the repository to analyze
PROJECT_PATH=/path/to/your/repo

# Task and reference input directories (upload via Dashboard or place files here)
TASK_INPUT_DIR=./inputs/tasks
REQUIREMENTS_DIR=./inputs/requirements
LOGS_DIR=./inputs/logs
REFERENCE_DIR=./inputs/reference

# ── LLM Configuration ──────────────────────────────────────────────────────
#
# Option A: Ollama (local, free)
LLM_PROVIDER=local
API_BASE=http://localhost:11434/v1
OPENAI_API_KEY=ollama
MODEL=qwen3.5
FAST_MODEL=qwen3.5
CODEGEN_MODEL=qwen3.5
VISION_MODEL=qwen3.5
#
# Option B: OpenAI API
# LLM_PROVIDER=onprem
# API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=sk-your-key-here
# MODEL=gpt-4o
# FAST_MODEL=gpt-4o-mini
# CODEGEN_MODEL=gpt-4o
# VISION_MODEL=gpt-4o
#
# Option C: On-Prem LLM (LiteLLM, vLLM, etc.)
# LLM_PROVIDER=onprem
# API_BASE=https://your-litellm.example.com/v1
# OPENAI_API_KEY=sk-your-key-here
# MODEL=openai/code
# FAST_MODEL=openai/code
# CODEGEN_MODEL=openai/code
# VISION_MODEL=openai/vision

# ── Token limits ─────────────────────────────────────────────────────────────
MAX_LLM_OUTPUT_TOKENS=8192
LLM_CONTEXT_WINDOW=32768

# ── Phase-specific LLM temperatures ────────────────────────────────────────
# LLM_TEMPERATURE=1.0              # Global default
# LLM_TEMPERATURE_ANALYZE=0.5
# LLM_TEMPERATURE_DOCUMENT=0.5
# LLM_TEMPERATURE_TRIAGE=0.7
# LLM_TEMPERATURE_PLAN=0.6
# LLM_TEMPERATURE_RETRY=0.3

# ── Quality Gates ──────────────────────────────────────────────────────────
# QUALITY_GATE_THRESHOLD=70
# QUALITY_GATE_MINIMUM=50

# ── Embeddings ─────────────────────────────────────────────────────────────
EMBED_MODEL=nomic-embed-text

# ── Output & indexing ──────────────────────────────────────────────────────
INDEX_MODE=auto
OUTPUT_DIR=./knowledge/architecture
DOCS_OUTPUT_DIR=./architecture-docs

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Code generation ────────────────────────────────────────────────────────
# CODEGEN_BUILD_VERIFY=false

# ══════════════════════════════════════════════════════════════════════════════
# Platform Services — start with: docker-compose -f docker-compose.local.yml up -d
# ══════════════════════════════════════════════════════════════════════════════

# ── Qdrant Vector Store ───────────────────────────────────────────────────
VECTOR_DB=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=repo_docs

# ── Langfuse LLM Observability ────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=lf-pk-local
LANGFUSE_SECRET_KEY=lf-sk-local
LANGFUSE_HOST=http://localhost:3000

# ── MLflow Experiment Tracking ────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=sdlc-pilot

# ── Prometheus / Grafana Metrics ──────────────────────────────────────────
PROMETHEUS_ENABLED=true
# Grafana: http://localhost:3001 (admin/admin)

# ── Dashboard port (Docker only) ──────────────────────────────────────────
# PORT=80
