# AI Code Generation Crew - Configuration

# Repository (einziger Pflichtwert, falls nicht via CLI übergeben)
PROJECT_PATH=C:\path\to\your\repo
INCLUDE_SUBMODULES=true

# Phase 4: Input Folders (OUTSIDE the code repository!)
# Set these to where YOUR task files live on your machine.
# Docker: these are mounted as volumes (see docker-compose.yml)
# Wheel:  set absolute paths to your local directories
TASK_INPUT_DIR=C:\work\my-project\tasks         # JIRA XML, DOCX, PDF, TXT
REQUIREMENTS_DIR=C:\work\my-project\requirements # Requirements docs (Excel, DOCX, PDF)
LOGS_DIR=C:\work\my-project\logs                 # Log files (.log, .txt, .xlsx)
REFERENCE_DIR=C:\work\my-project\reference       # Reference docs (mockups, diagrams)

# LLM Provider (onprem)
LLM_PROVIDER=onprem
MODEL=gpt-oss-120b
API_BASE=http://sov-ai-platform.nue.local.vm:4000/v1
OPENAI_API_KEY=your-api-key-here

# Token limits (optimized for gpt-oss-120b: 120K context window)
MAX_LLM_INPUT_TOKENS=100000
MAX_LLM_OUTPUT_TOKENS=16000
LLM_CONTEXT_WINDOW=120000

# Embeddings (local Ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_S=300
OLLAMA_MAX_RETRIES=3
EMBED_MODEL=nomic-embed-text:latest


# Token budget is calculated from MAX_LLM_INPUT_TOKENS (see token_budget.py)
# Tool responses use 25% of input budget = 8000 tokens = ~32000 chars

# Phase Control
# SKIP_SYNTHESIS=true          # Skip Phase 3 (C4/Arc42 markdown generation)
# INDEX_MODE=off               # Skip Phase 0 (ChromaDB indexing)

# Phase 3 Architecture Docs Export
# After Phase 3, C4 + Arc42 docs are copied here (no intermediate JSON files).
# Default: ./architecture-docs
# Override to export to a shared drive or external folder for the architect.
# DOCS_OUTPUT_DIR=./architecture-docs

# Arc42 Table of Contents language (en = English, de = Deutsch)
ARC42_LANGUAGE=en

# Logging
LOG_LEVEL=INFO
CREWAI_TRACING_ENABLED=false
