# =============================================================================
# SDLC Pilot - Configuration
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   copy .env.example .env      (Windows)
#   cp .env.example .env        (macOS/Linux)
#
# =============================================================================

# Path to the repository to analyze (restart required after change in Docker)
PROJECT_PATH=/mnt/c/path/to/your/repo

# Task and reference input directories (upload via Dashboard or place files here)
TASK_INPUT_DIR=./inputs/tasks
REQUIREMENTS_DIR=./inputs/requirements
LOGS_DIR=./inputs/logs
REFERENCE_DIR=./inputs/reference

# LLM provider and API connection
LLM_PROVIDER=onprem
# Internal Capgemini LiteLLM proxy endpoint (for on-prem distribution)
API_BASE=https://litellm.bnotk.sovai-de.apps.ce.capgemini.com/v1
OPENAI_API_KEY=sk-your-api-key-here

# Architecture, documentation, planning, reviews
MODEL=openai/code

# Fast tasks (triage, classification)
FAST_MODEL=openai/code

# Code generation, tool use, agentic coding
CODEGEN_MODEL=openai/code

# OCR, documents, multilingual
VISION_MODEL=openai/vision

# Token limits
MAX_LLM_OUTPUT_TOKENS=65536
LLM_CONTEXT_WINDOW=262144

# Embeddings
EMBED_MODEL=embed

# Indexing and output
INDEX_MODE=auto
OUTPUT_DIR=./knowledge/architecture
DOCS_OUTPUT_DIR=./architecture-docs

# Timezone (default: Europe/Berlin)
# TZ=Europe/Berlin

# Logging
LOG_LEVEL=INFO
CREWAI_TRACING_ENABLED=false

# ChromaDB (optional: client-server mode)
# If CHROMA_SERVER_HOST is set, semantic search uses HTTP instead of local SQLite.
# CHROMA_SERVER_HOST=127.0.0.1
# CHROMA_SERVER_PORT=8005
# CHROMA_SERVER_SSL=false

# Dashboard port (default: 80). Change if port 80 is in use.
# PORT=80

# Skip build verification (useful when build tools are unavailable)
# CODEGEN_BUILD_VERIFY=false
