        <mxCell id="label-filepaths" value="2934 paths" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontColor=#82b366;" vertex="1" parent="1">
