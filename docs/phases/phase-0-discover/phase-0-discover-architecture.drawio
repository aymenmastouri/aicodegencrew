<mxfile host="app.diagrams.net">
  <diagram id="phase0-pipeline" name="Phase 0 Indexing Pipeline (Enhanced)">
    <mxGraphModel dx="1822" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Phase 0: Repository Indexing Pipeline (Enhanced v0.6.0)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="700" height="40" as="geometry" />
        </mxCell>

        <!-- Subtitle -->
        <mxCell id="subtitle" value="10 steps | 0 LLM calls | 100% deterministic | 3 languages | 3 output artifacts + ChromaDB" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="350" y="60" width="800" height="30" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- INPUT SOURCES (left column) -->
        <!-- ================================================================ -->

        <mxCell id="input-label" value="Inputs" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="200" height="30" as="geometry" />
        </mxCell>

        <mxCell id="input-repo" value="Target Repository&#xa;(e.g. C:\uvz — 2934 files)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="160" width="200" height="50" as="geometry" />
        </mxCell>

        <mxCell id="input-config" value=".env Configuration&#xa;(INDEX_MODE, CHUNK_SIZE,&#xa;BUDGET settings)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="200" height="55" as="geometry" />
        </mxCell>

        <mxCell id="input-ollama" value="Ollama Server&#xa;(nomic-embed-text model)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="285" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- STAGE 1: Discover Files -->
        <!-- ================================================================ -->

        <mxCell id="stage1" value="Step 1: Discover Files&#xa;(RepoDiscoveryTool, &lt;1s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="320" y="120" width="220" height="55" as="geometry" />
        </mxCell>

        <mxCell id="stage1-desc" value="• Recursive filesystem traversal&#xa;• Filter noise: .git, node_modules,&#xa;  dist, build, __pycache__&#xa;• Filter by extension (.java, .ts, .py,&#xa;  .yaml, .json, .xml, .md, .sql, ...)&#xa;• Output: 2934 file paths" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="320" y="180" width="220" height="85" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- STAGE 1b: Repo Manifest (NEW) -->
        <!-- ================================================================ -->

        <mxCell id="stage1b" value="Step 1b: Build Manifest&#xa;(ManifestBuilder, &lt;1s)  [NEW]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="320" y="280" width="220" height="55" as="geometry" />
        </mxCell>

        <mxCell id="stage1b-desc" value="• Detect frameworks via marker files:&#xa;  angular.json → Angular&#xa;  build.gradle → Spring/Gradle&#xa;  package.json → Node.js&#xa;• File stats per extension + module&#xa;• Git commit hash (rev-parse HEAD)&#xa;• Output: repo_manifest.json" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="320" y="340" width="220" height="95" as="geometry" />
        </mxCell>

        <!-- Example box for manifest -->
        <mxCell id="manifest-example" value="Example repo_manifest.json:&#xa;{&#xa;  &quot;frameworks&quot;: [&quot;Angular&quot;, &quot;Spring/Gradle&quot;],&#xa;  &quot;modules&quot;: [&#xa;    {&quot;name&quot;: &quot;backend&quot;, &quot;file_count&quot;: 1516},&#xa;    {&quot;name&quot;: &quot;frontend&quot;, &quot;file_count&quot;: 1314}&#xa;  ],&#xa;  &quot;stats&quot;: {&quot;total_files&quot;: 2934, ...}&#xa;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=8;fontFamily=Courier New;align=left;verticalAlign=top;spacingLeft=5;spacingTop=3;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="320" y="440" width="220" height="120" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- STAGE 2: Read Files -->
        <!-- ================================================================ -->

        <mxCell id="stage2" value="Step 2: Read Files&#xa;(RepoReaderTool, batches of 50)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="620" y="120" width="220" height="55" as="geometry" />
        </mxCell>

        <mxCell id="stage2-desc" value="• Read file content as text&#xa;• UTF-8 with fallback decoding&#xa;• Skip binary files&#xa;• 50 files per batch&#xa;• Output: file content + metadata" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="620" y="180" width="220" height="75" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- STAGE 2b: Symbol Extraction (NEW) -->
        <!-- ================================================================ -->

        <mxCell id="stage2b" value="Step 2b: Extract Symbols&#xa;(SymbolExtractor, per file)  [NEW]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="620" y="270" width="220" height="55" as="geometry" />
        </mxCell>

        <mxCell id="stage2b-desc" value="• Java: classes, methods, @RestController,&#xa;  @Service, @GetMapping, @PostMapping&#xa;• TypeScript: classes, interfaces,&#xa;  functions, @Component, @Injectable&#xa;• Python: classes, functions, decorators&#xa;• Output: ~15,000 SymbolRecords" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="620" y="330" width="220" height="85" as="geometry" />
        </mxCell>

        <!-- Example box for symbols -->
        <mxCell id="symbol-example" value="Example symbols.jsonl:&#xa;{&quot;symbol&quot;: &quot;AuthController&quot;, &quot;kind&quot;: &quot;class&quot;,&#xa; &quot;path&quot;: &quot;backend/.../AuthController.java&quot;,&#xa; &quot;line&quot;: 12, &quot;end_line&quot;: 89,&#xa; &quot;language&quot;: &quot;java&quot;,&#xa; &quot;refs&quot;: [&quot;@RestController&quot;],&#xa; &quot;module&quot;: &quot;backend&quot;}&#xa;&#xa;{&quot;symbol&quot;: &quot;login&quot;, &quot;kind&quot;: &quot;endpoint&quot;,&#xa; &quot;path&quot;: &quot;backend/.../AuthController.java&quot;,&#xa; &quot;line&quot;: 34, &quot;end_line&quot;: 52,&#xa; &quot;refs&quot;: [&quot;@PostMapping(\&quot;/login\&quot;)&quot;]}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=8;fontFamily=Courier New;align=left;verticalAlign=top;spacingLeft=5;spacingTop=3;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="620" y="420" width="220" height="165" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- STAGE 2c: Budget Engine (NEW) -->
        <!-- ================================================================ -->

        <mxCell id="stage2c" value="Step 2c: Budget Prioritization&#xa;(BudgetEngine, &lt;1s)  [NEW]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="920" y="120" width="220" height="55" as="geometry" />
        </mxCell>

        <mxCell id="stage2c-desc" value="• Tier A (40%): controllers, README,&#xa;  root configs, Angular modules&#xa;• Tier B (40%): services, repositories,&#xa;  entities, components, 3+ symbols&#xa;• Tier C (20%): tests, utils, generated&#xa;• Reorders file queue by priority&#xa;• ENV: INDEX_ENABLE_BUDGET=true" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="920" y="180" width="220" height="95" as="geometry" />
        </mxCell>

        <!-- Budget visualization -->
        <mxCell id="budget-viz-a" value="Tier A — 40%&#xa;AuthController.java, application.yaml, README.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="920" y="285" width="220" height="40" as="geometry" />
        </mxCell>

        <mxCell id="budget-viz-b" value="Tier B — 40%&#xa;AuthService.java, user.component.ts, User.java" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="920" y="330" width="220" height="40" as="geometry" />
        </mxCell>

        <mxCell id="budget-viz-c" value="Tier C — 20%&#xa;AuthServiceTest.java, test-utils.ts, *.d.ts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="920" y="375" width="220" height="40" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- STAGE 3: Chunk -->
        <!-- ================================================================ -->

        <mxCell id="stage3" value="Step 3: Chunk&#xa;(ChunkerTool, enhanced)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="920" y="440" width="220" height="55" as="geometry" />
        </mxCell>

        <mxCell id="stage3-desc" value="• Semantic segmentation (1500 chars)&#xa;• 200 char overlap between chunks&#xa;• NEW: content_type per chunk:&#xa;  .java/.ts → code&#xa;  .md/.txt → doc&#xa;  .yaml/.json → config&#xa;• NEW: evidence record per chunk&#xa;  with line numbers + linked symbols" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="920" y="500" width="220" height="110" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- STAGE 4: Embed -->
        <!-- ================================================================ -->

        <mxCell id="stage4" value="Step 4: Embed&#xa;(OllamaEmbeddingsTool)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1220" y="120" width="220" height="55" as="geometry" />
        </mxCell>

        <mxCell id="stage4-desc" value="• Ollama nomic-embed-text model&#xa;• 768-dim vectors per chunk&#xa;• Batch embedding via REST API&#xa;• Only non-LLM AI call in pipeline" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1220" y="180" width="220" height="65" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- STAGE 5: Store in ChromaDB -->
        <!-- ================================================================ -->

        <mxCell id="stage5" value="Step 5: Store in ChromaDB&#xa;(ChromaIndexTool, enhanced)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1220" y="270" width="220" height="55" as="geometry" />
        </mxCell>

        <mxCell id="stage5-desc" value="• Persist vectors + metadata&#xa;• Metadata: file path, hash&#xa;• NEW: content_type in metadata&#xa;  → enables filtered RAG queries&#xa;• ~25,000 chunks for UVZ repo" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1220" y="330" width="220" height="75" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- STAGE 6: Write Artifacts (NEW) -->
        <!-- ================================================================ -->

        <mxCell id="stage6" value="Step 6: Write Artifacts&#xa;(symbols.jsonl + evidence.jsonl)  [NEW]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1220" y="430" width="220" height="55" as="geometry" />
        </mxCell>

        <mxCell id="stage6-desc" value="• Write accumulated symbols → JSONL&#xa;• Write accumulated evidence → JSONL&#xa;• Update .indexing_state.json:&#xa;  symbols_count, evidence_count,&#xa;  manifest_generated" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1220" y="490" width="220" height="75" as="geometry" />
        </mxCell>

        <!-- Evidence example -->
        <mxCell id="evidence-example" value="Example evidence.jsonl:&#xa;{&quot;chunk_id&quot;: &quot;abc123&quot;,&#xa; &quot;path&quot;: &quot;backend/.../AuthService.java&quot;,&#xa; &quot;type&quot;: &quot;code&quot;,&#xa; &quot;start_line&quot;: 15, &quot;end_line&quot;: 56,&#xa; &quot;symbols&quot;: [&quot;AuthService&quot;, &quot;authenticate&quot;],&#xa; &quot;language&quot;: &quot;java&quot;,&#xa; &quot;module&quot;: &quot;backend&quot;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=8;fontFamily=Courier New;align=left;verticalAlign=top;spacingLeft=5;spacingTop=3;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1220" y="575" width="220" height="120" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- OUTPUT ARTIFACTS (bottom) -->
        <!-- ================================================================ -->

        <mxCell id="output-label" value="Output Artifacts (knowledge/discover/)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#9673a6" vertex="1" parent="1">
          <mxGeometry x="40" y="720" width="400" height="30" as="geometry" />
        </mxCell>

        <mxCell id="output-chroma" value="chroma.sqlite3&#xa;(~25,000 vectors + content_type)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="760" width="220" height="50" as="geometry" />
        </mxCell>

        <mxCell id="output-symbols" value="symbols.jsonl  [NEW]&#xa;(~15,000 symbol records)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="280" y="760" width="220" height="50" as="geometry" />
        </mxCell>

        <mxCell id="output-evidence" value="evidence.jsonl  [NEW]&#xa;(~25,000 evidence records)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="520" y="760" width="220" height="50" as="geometry" />
        </mxCell>

        <mxCell id="output-manifest" value="repo_manifest.json  [NEW]&#xa;(frameworks, modules, stats)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="760" y="760" width="220" height="50" as="geometry" />
        </mxCell>

        <mxCell id="output-state" value=".indexing_state.json&#xa;(fingerprint, counts, timestamp)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=0" vertex="1" parent="1">
          <mxGeometry x="1000" y="760" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- DOWNSTREAM CONSUMERS (right side, bottom) -->
        <!-- ================================================================ -->

        <mxCell id="downstream-label" value="Downstream Consumers" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="40" y="840" width="400" height="30" as="geometry" />
        </mxCell>

        <mxCell id="consumer-extract" value="Phase 1: Extract&#xa;CollectorOrchestrator&#xa;uses repo_manifest.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="880" width="200" height="55" as="geometry" />
        </mxCell>

        <mxCell id="consumer-plan" value="Phase 4: Plan&#xa;ComponentDiscovery uses&#xa;symbols as 5th scoring signal&#xa;(semantic 30%, name 25%,&#xa;symbol 20%, pkg 15%, stereo 10%)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="260" y="880" width="210" height="75" as="geometry" />
        </mxCell>

        <mxCell id="consumer-implement" value="Phase 5: Implement&#xa;ContextCollector uses symbols&#xa;for targeted extraction&#xa;(exact method body + 5 lines&#xa;context instead of 12K truncation)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="490" y="880" width="210" height="75" as="geometry" />
        </mxCell>

        <mxCell id="consumer-rag" value="Shared: RAGQueryTool&#xa;Enriched with evidence metadata&#xa;(line numbers, content_type,&#xa;linked symbols) + type filter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="720" y="880" width="210" height="65" as="geometry" />
        </mxCell>

        <mxCell id="consumer-symbol-tool" value="Shared: SymbolQueryTool&#xa;Deterministic lookups&#xa;(exact/substring match,&#xa;filter by kind/path/module)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="950" y="880" width="210" height="65" as="geometry" />
        </mxCell>

