        <!-- ARROWS: Main Pipeline Flow -->
        <!-- ================================================================ -->

        <!-- Input -> Stage 1 -->
        <mxCell id="arrow-input-stage1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="input-repo" target="stage1">
