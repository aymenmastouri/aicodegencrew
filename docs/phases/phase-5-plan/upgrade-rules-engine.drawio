        <mxCell id="rule-angular-desc" value="4 rule sets | 17 rules&#xa;18→19: Standalone, Builder, Sass, TS 5.6, Zone.js (6 rules)&#xa;19→20: Control flow, Karma, InjectFlags, HammerJS (4 rules)&#xa;Signals: @Input→input(), @Output→output(), @ViewChild (4 rules)&#xa;Third-party: AG Grid, ng-bootstrap, ngx-translate (3 rules)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;" vertex="1" parent="1">
