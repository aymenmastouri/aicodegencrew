        </mxCell>

        <!-- ============ JSON REPAIR FLOW ============ -->
        <mxCell id="repair-title" value="_extract_and_repair_json() — JSON Repair Pipeline" style="text;html=1;strokeColor=none;fillColor=#2e7d32;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=12;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
