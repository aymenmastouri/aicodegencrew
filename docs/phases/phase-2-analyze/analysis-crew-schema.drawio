        <mxCell id="arr-s2-ok" value="OK" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2e7d32;fontColor=#2e7d32;fontSize=10;endArrow=block;endFill=1;" edge="1" source="step2" target="section-out" parent="1">
