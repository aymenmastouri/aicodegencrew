        <!-- Section IDs table -->
        <mxCell id="section-ids" value="Section IDs (01–16):&#xa;01 Macro Architecture   |  09 Workflow Engines&#xa;02 Backend Pattern      |  10 Saga Patterns&#xa;03 Frontend Pattern     |  11 Runtime Scenarios&#xa;04 Architecture Quality |  12 API Design&#xa;05 Domain Model         |  13 Complexity&#xa;06 Business Capabilities|  14 Technical Debt&#xa;07 Bounded Contexts     |  15 Security&#xa;08 State Machines       |  16 Operational Readiness" style="text;html=1;strokeColor=#6c8ebf;fillColor=#f0f7ff;align=left;fontSize=10;fontFamily=Courier New;rounded=1;spacingLeft=8;spacingTop=5;" vertex="1" parent="1">
