        <mxCell id="syn-spb" value="&lt;b&gt;SynthesisPromptBuilder(BasePromptBuilder)&lt;/b&gt;&#xa;.build({&quot;sections&quot;: {filename: section_content}})&#xa;Merges all 16 section files into one prompt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;" vertex="1" parent="1">
