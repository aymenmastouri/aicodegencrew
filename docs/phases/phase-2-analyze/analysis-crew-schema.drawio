        </mxCell>

        <mxCell id="step1" value="&lt;b&gt;Step 1: Strip Markdown Fences&lt;/b&gt;&#xa;Remove ```json ... ``` wrappers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="990" y="125" width="300" height="55" as="geometry" />
        </mxCell>
        <mxCell id="step2" value="&lt;b&gt;Step 2: Direct json.loads()&lt;/b&gt;&#xa;Try direct parse — success → done" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="990" y="195" width="300" height="55" as="geometry" />
        </mxCell>
        <mxCell id="step3" value="&lt;b&gt;Step 3: Reconstruct Unclosed Structures&lt;/b&gt;&#xa;Stack-based bracket closer (handles truncated&#xa;LLM output — missing }, ], or &quot;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="990" y="265" width="300" height="65" as="geometry" />
        </mxCell>
        <mxCell id="step4" value="&lt;b&gt;Step 4: json.loads() on repaired string&lt;/b&gt;&#xa;Success → section dict saved&#xa;Failure → section marked failed, skipped" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="990" y="345" width="300" height="65" as="geometry" />
        </mxCell>

