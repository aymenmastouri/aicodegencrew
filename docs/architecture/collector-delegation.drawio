          <mxGeometry x="15" y="215" width="190" height="30" as="geometry" />
        </mxCell>
        <mxCell id="r7" value="SecurityDetailCollector" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3949ab;fontSize=10" vertex="1" parent="routers-group">
          <mxGeometry x="15" y="250" width="190" height="30" as="geometry" />
        </mxCell>
        <mxCell id="r8" value="ValidationCollector" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3949ab;fontSize=10" vertex="1" parent="routers-group">
          <mxGeometry x="15" y="285" width="190" height="30" as="geometry" />
        </mxCell>
        <mxCell id="r9" value="ErrorHandlingCollector" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3949ab;fontSize=10" vertex="1" parent="routers-group">
          <mxGeometry x="15" y="320" width="190" height="30" as="geometry" />
        </mxCell>
        <mxCell id="r10" value="InterfaceCollector  ⊕ OpenAPI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3949ab;fontSize=10" vertex="1" parent="routers-group">
          <mxGeometry x="15" y="355" width="190" height="30" as="geometry" />
        </mxCell>

        <mxCell id="crosscut-note" value="⊕ = cross-cutting logic&#xa;    stays in router" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=9;fontStyle=2;fontColor=#666666" vertex="1" parent="routers-group">
          <mxGeometry x="15" y="400" width="190" height="30" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- CENTER: EcosystemRegistry                          -->
        <!-- ═══════════════════════════════════════════════════ -->

        <mxCell id="registry" value="EcosystemRegistry&#xa;━━━━━━━━━━━━━━━━━━━━━&#xa;detect(repo_path)&#xa;→ active ecosystems&#xa;&#xa;for eco in active:&#xa;  eco.collect_dimension(&#xa;    dimension,&#xa;    repo_path,&#xa;    container_id&#xa;  )" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="350" y="340" width="230" height="180" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
