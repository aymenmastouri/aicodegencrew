<mxfile host="app.diagrams.net" modified="2026-03-17T00:00:00.000Z" agent="AICodeGenCrew" version="22.1.0" type="device">
  <diagram id="delegation" name="Collector Delegation Pattern">
    <mxGraphModel dx="1600" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Collector Delegation Pattern — Ecosystem Strategy for All Dimensions" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <mxCell id="subtitle" value="Dimension Collectors are thin routers (~40-80 lines). Ecosystem-specific logic lives in specialist files." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=2;fontColor=#666666" vertex="1" parent="1">
          <mxGeometry x="300" y="55" width="600" height="30" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- LEFT: Orchestrator + Dimension Collectors          -->
        <!-- ═══════════════════════════════════════════════════ -->

        <mxCell id="orch" value="Orchestrator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- Dimension Collectors (thin routers) -->
        <mxCell id="routers-group" value="Dimension Collectors (thin routers)" style="swimlane;horizontal=1;startSize=30;fillColor=#e8eaf6;strokeColor=#3949ab;rounded=1;fontStyle=1;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="220" height="470" as="geometry" />
        </mxCell>

        <mxCell id="r1" value="RuntimeCollector" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3949ab;fontSize=10" vertex="1" parent="routers-group">
          <mxGeometry x="15" y="40" width="190" height="30" as="geometry" />
        </mxCell>
        <mxCell id="r2" value="DependencyCollector" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3949ab;fontSize=10" vertex="1" parent="routers-group">
          <mxGeometry x="15" y="75" width="190" height="30" as="geometry" />
        </mxCell>
        <mxCell id="r3" value="TestCollector  ⊕ Cucumber" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3949ab;fontSize=10" vertex="1" parent="routers-group">
          <mxGeometry x="15" y="110" width="190" height="30" as="geometry" />
        </mxCell>
        <mxCell id="r4" value="DataModelCollector  ⊕ SQL/Migration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3949ab;fontSize=10" vertex="1" parent="routers-group">
          <mxGeometry x="15" y="145" width="190" height="30" as="geometry" />
        </mxCell>
        <mxCell id="r5" value="WorkflowCollector  ⊕ BPMN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3949ab;fontSize=10" vertex="1" parent="routers-group">
          <mxGeometry x="15" y="180" width="190" height="30" as="geometry" />
        </mxCell>
