        <mxCell id="sp-benefit" value="New ecosystem =&#xa;new files only.&#xa;Zero changes to&#xa;existing code." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left" vertex="1" parent="specialists">
