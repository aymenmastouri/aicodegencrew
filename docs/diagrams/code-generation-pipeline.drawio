          <mxGeometry x="1130" y="160" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="stage4-desc" value="• Syntax: balanced braces/parens&#xa;• Security: 7 anti-patterns&#xa;  (eval, hardcoded secrets,&#xa;  SQL concat, innerHTML)&#xa;• Patterns: class name matches&#xa;  file, TS has exports&#xa;• Generates unified diff&#xa;• Per-file: valid/invalid + errors" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1130" y="225" width="200" height="110" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
