        <mxCell id="strategy-desc" value="• FeatureStrategy (create / modify)&#xa;• BugfixStrategy (minimal changes)&#xa;• UpgradeStrategy (migration rules)&#xa;• RefactoringStrategy (preserve API)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;" vertex="1" parent="1">
