        <!-- ================================================================ -->

        <mxCell id="stage5" value="Stage 5: Output Writer&#xa;(Git + File I/O, 2-5s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1130" y="380" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="stage5-desc" value="• Safety: abort if dirty tree&#xa;• Create branch codegen/{task_id}&#xa;• Write only valid files&#xa;• Explicit file staging (no -A)&#xa;• Git commit with task metadata&#xa;• Switch back to original branch&#xa;• &gt;50% fail threshold → abort&#xa;• Dry-run: skip writes + git" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1130" y="445" width="200" height="110" as="geometry" />
