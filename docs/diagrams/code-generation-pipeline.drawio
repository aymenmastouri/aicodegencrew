          <mxGeometry x="590" y="160" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="stage2-desc" value="• Read source files from target repo&#xa;• Detect language (java/ts/html/scss)&#xa;• Find sibling files in same package&#xa;• Attach related patterns from plan&#xa;• Truncate files &gt;15000 chars&#xa;• Skip missing modify-files,&#xa;  accept missing create-files" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="590" y="225" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- Stage 3: Code Generator (LLM - RED) -->
        <!-- ================================================================ -->

        <mxCell id="stage3" value="Stage 3: Code Generator&#xa;(LLM, 10-30s per file)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="860" y="160" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="stage3-desc" value="• 1 LLM call per file&#xa;• Strategy builds prompt&#xa;  (modify/create/delete)&#xa;• Strategy post-processes output&#xa;  (extract code block, restore&#xa;  imports for upgrades)&#xa;• Retry with backoff (max 2)&#xa;• Delete: no LLM call needed" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="860" y="225" width="200" height="110" as="geometry" />
        </mxCell>

