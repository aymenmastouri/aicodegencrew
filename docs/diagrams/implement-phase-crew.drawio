        <mxCell id="tst-goal" value="&lt;b&gt;Goal:&lt;/b&gt; Create comprehensive tests for all code changes.&lt;br&gt;Match the existing test patterns and frameworks used in&lt;br&gt;the target repository. JUnit 5 + Mockito for Spring Boot,&lt;br&gt;Jasmine + TestBed for Angular." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="1050" y="405" width="330" height="56" as="geometry" />
        </mxCell>

        <!-- Tester Workflow -->
        <mxCell id="tst-wf-title" value="&lt;b&gt;Workflow:&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#7b1fa2;" vertex="1" parent="1">
