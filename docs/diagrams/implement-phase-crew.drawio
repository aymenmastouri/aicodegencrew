        </mxCell>
        <mxCell id="tst-wf" value="1. Query existing test patterns (TestPattern)&lt;br&gt;2. Read changed file (CodeReader)&lt;br&gt;3. Query similar tests via RAG (RAGQuery)&lt;br&gt;4. Generate unit tests matching conventions&lt;br&gt;5. Write tests to staging (TestWriter)&lt;br&gt;6. Verify test file structure" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="1050" y="490" width="330" height="82" as="geometry" />
