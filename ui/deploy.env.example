# LLM Server (provided by your infrastructure team)
LLM_PROVIDER=onprem
MODEL=gpt-oss-120b
API_BASE=https://llm-server.firma.internal:4000

# Ports (optional, defaults shown)
FRONTEND_PORT=80
BACKEND_PORT=8001

# Image tag (optional)
TAG=latest
