# =============================================================================
# AICodeGenCrew Backend — lightweight dev/demo image
# Build context: project root (so certs/, src/, pyproject.toml are accessible)
# =============================================================================
FROM python:3.12-slim

WORKDIR /app

# Install Capgemini corporate CA so HTTPS to Sovereign AI Platform works
COPY certs/CapgeminiPKIRootCA.crt /usr/local/share/ca-certificates/CapgeminiPKIRootCA.crt
RUN update-ca-certificates

# Install backend-specific dependencies
COPY ui/backend/requirements.txt /tmp/backend-requirements.txt
RUN pip install --no-cache-dir -r /tmp/backend-requirements.txt

# Install core package with all its dependencies (requests, crewai, etc.)
COPY pyproject.toml README.md ./
COPY src/ /app/src/
RUN pip install --no-cache-dir -e . && \
    pip install --no-cache-dir truststore>=0.9.0

# Copy backend code
COPY ui/backend/ /app/ui/backend/

ENV PYTHONPATH=/app/src:/app
ENV PYTHONDONTWRITEBYTECODE=1

EXPOSE 8001

CMD ["python", "-m", "uvicorn", "ui.backend.main:app", "--host", "0.0.0.0", "--port", "8001"]
