# =============================================================================
# AICodeGenCrew Backend — lightweight dev/demo image
# Build context: project root (so certs/ and src/ are accessible)
# =============================================================================
FROM python:3.12-slim

WORKDIR /app

# Install Capgemini corporate CA so HTTPS to Sovereign AI Platform works
COPY certs/CapgeminiPKIRootCA.crt /usr/local/share/ca-certificates/CapgeminiPKIRootCA.crt
RUN update-ca-certificates

# Install backend + core dependencies
COPY ui/backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# truststore for corporate SSL (uses OS cert store — now includes Capgemini CA)
RUN pip install --no-cache-dir truststore>=0.9.0

# Copy backend code
COPY ui/backend/ /app/ui/backend/

# Copy core aicodegencrew package
COPY src/ /app/src/

ENV PYTHONPATH=/app/src:/app
ENV PYTHONDONTWRITEBYTECODE=1

EXPOSE 8001

CMD ["python", "-m", "uvicorn", "ui.backend.main:app", "--host", "0.0.0.0", "--port", "8001"]
